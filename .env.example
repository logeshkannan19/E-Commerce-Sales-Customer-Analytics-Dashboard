# E-Commerce Analytics Environment Variables
# Copy this file to .env and update with your values

# Data paths
DATA_RAW_PATH=data/raw/ecommerce_data.csv
DATA_PROCESSED_PATH=data/processed/ecommerce_processed.csv
DATA_OUTPUT_DIR=data/processed

# Dashboard settings
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8501

# Database (optional - for SQL analysis)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce
DB_USER=postgres
DB_PASSWORD=your_password_here

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/analytics.log

# Analytics parameters
RFM_QUARTILES=5
TOP_CUSTOMERS_PERCENT=10
VIP_THRESHOLD=13
LOYAL_THRESHOLD=10
AT_RISK_THRESHOLD=5