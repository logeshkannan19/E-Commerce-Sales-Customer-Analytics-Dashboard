# Shopify Integration
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxx
SHOPIFY_API_KEY=xxxxxxxxxx
SHOPIFY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dropagent
DATABASE_POOL_SIZE=20

# ML Pipeline
ML_API_URL=http://localhost:8000
ML_API_KEY=your-ml-api-key
ML_MODEL_VERSION=v2.1

# Application
NODE_ENV=development
PORT=5173
API_PORT=3000

# Redis (caching layer)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-jwt-secret-change-in-production
SESSION_SECRET=your-session-secret

# Monitoring
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
LOG_LEVEL=debug

# Third-party APIs
ALIPAY_API_KEY=xxxxx
AMAZON_API_KEY=xxxxx
TIKTOK_API_KEY=xxxxx